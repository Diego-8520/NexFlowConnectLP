---
const navItems = [
  { label: "Inicio", href: "#inicio" },
  { label: "Problema", href: "#problema" },
  { label: "Solución", href: "#solucion" },
  { label: "Planes", href: "#planes" },
  { label: "Contacto", href: "#contacto" },
];
---

<header class="navbar" id="navbar">
  <div class="nav-inner">
    <!-- Brand -->
    <a href="#inicio" class="brand" aria-label="Nexflow Connect">
      <img
        src="/logo solid color 160 sin fondo.svg"
        alt="Nexflow Connect"
        class="brand-logo"
      />
      <span class="brand-text">Nexflow Connect</span>
    </a>

    <!-- Desktop links -->
    <nav aria-label="Navegación principal">
      <ul class="nav-links">
        {
          navItems.map((item) => (
            <li>
              <a href={item.href}>{item.label}</a>
            </li>
          ))
        }
      </ul>
    </nav>

    <!-- CTA + hamburger -->
    <div class="nav-right">
      <a href="#contacto" class="nav-cta">Quiero más reservas</a>

      <button
        class="menu-btn"
        id="menuBtn"
        aria-label="Abrir menú"
        aria-expanded="false"
      >
        <span class="bar"></span>
        <span class="bar"></span>
        <span class="bar"></span>
      </button>
    </div>
  </div>

  <!-- Mobile drawer -->
  <div class="mobile-menu" id="mobileMenu" aria-hidden="true">
    <nav>
      {
        navItems.map((item) => (
          <a href={item.href} class="mobile-link">
            {item.label}
          </a>
        ))
      }
    </nav>
    <a href="#contacto" class="mobile-cta">Agenda un diagnóstico →</a>
  </div>
</header>

<script>
  const navbar = document.getElementById("navbar")!;
  const menuBtn = document.getElementById("menuBtn")!;
  const mobileMenu = document.getElementById("mobileMenu")!;

  /* ── Hide / show on scroll ── */
  let lastY = window.scrollY;
  let ticking = false;

  window.addEventListener("scroll", () => {
    if (!ticking) {
      requestAnimationFrame(() => {
        const currentY = window.scrollY;
        const goingDown = currentY > lastY;

        if (currentY > 80) {
          if (goingDown) {
            navbar.classList.add("is-hidden");
          } else {
            navbar.classList.remove("is-hidden");
          }
        } else {
          navbar.classList.remove("is-hidden");
        }

        lastY = currentY;
        ticking = false;
      });
      ticking = true;
    }
  });

  /* ── Mobile menu toggle ── */
  menuBtn.addEventListener("click", () => {
    const isOpen = menuBtn.classList.toggle("is-open");
    mobileMenu.classList.toggle("is-open");
    menuBtn.setAttribute("aria-expanded", String(isOpen));
    mobileMenu.setAttribute("aria-hidden", String(!isOpen));
    document.body.classList.toggle("menu-open", isOpen);
  });

  mobileMenu.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => {
      menuBtn.classList.remove("is-open");
      mobileMenu.classList.remove("is-open");
      menuBtn.setAttribute("aria-expanded", "false");
      mobileMenu.setAttribute("aria-hidden", "true");
      document.body.classList.remove("menu-open");
    });
  });
</script>

<style>
  /* ════════════════════════════════════
     BASE
  ════════════════════════════════════ */
  .navbar {
    position: fixed;
    top: 0;
    left: 0;
    z-index: 1000;
    width: 100%;
    background: #fff;
    border-bottom: 1px solid rgba(27, 63, 110, 0.07);
    box-shadow: 0 1px 24px rgba(27, 63, 110, 0.08);
    transform: translateY(0);
    transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .navbar.is-hidden {
    transform: translateY(-100%);
  }

  /* ════════════════════════════════════
     INNER LAYOUT
  ════════════════════════════════════ */
  .nav-inner {
    max-width: 1200px;
    margin: 0 auto;
    height: 72px;
    padding: 0 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  /* ════════════════════════════════════
     BRAND
  ════════════════════════════════════ */
  .brand {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    flex-shrink: 0;
  }

  .brand-logo {
    width: 38px;
    height: 38px;
    object-fit: contain;
  }

  .brand-text {
    font-family: "Plus Jakarta Sans", sans-serif;
    font-size: 15px;
    font-weight: 800;
    color: #1b3f6e;
    letter-spacing: -0.03em;
  }

  /* ════════════════════════════════════
     DESKTOP NAV LINKS
  ════════════════════════════════════ */
  .nav-links {
    display: flex;
    align-items: center;
    gap: 2px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav-links a {
    position: relative;
    display: inline-flex;
    align-items: center;
    padding: 8px 14px;
    font-family: "Inter", sans-serif;
    font-size: 13.5px;
    font-weight: 500;
    color: #2c3e55;
    text-decoration: none;
    border-radius: 8px;
    transition:
      color 0.2s ease,
      background 0.2s ease;
  }

  .nav-links a:hover {
    color: #1b3f6e;
    background: rgba(27, 63, 110, 0.05);
  }

  .nav-links a::after {
    content: "";
    position: absolute;
    bottom: 2px;
    left: 14px;
    right: 14px;
    height: 1.5px;
    border-radius: 99px;
    background: #e8623a;
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.25s ease;
  }

  .nav-links a:hover::after {
    transform: scaleX(1);
  }

  /* ════════════════════════════════════
     RIGHT SIDE
  ════════════════════════════════════ */
  .nav-right {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .nav-cta {
    display: inline-flex;
    align-items: center;
    padding: 10px 20px;
    border-radius: 8px;
    background: #e8623a;
    font-family: "Plus Jakarta Sans", sans-serif;
    font-size: 13px;
    font-weight: 700;
    color: #fff;
    text-decoration: none;
    letter-spacing: 0.01em;
    transition:
      background 0.2s ease,
      transform 0.2s ease,
      box-shadow 0.2s ease;
    box-shadow: 0 4px 14px rgba(232, 98, 58, 0.28);
  }

  .nav-cta:hover {
    background: #d4542f;
    transform: translateY(-1px);
    box-shadow: 0 8px 22px rgba(232, 98, 58, 0.34);
  }

  /* ════════════════════════════════════
     HAMBURGER
  ════════════════════════════════════ */
  .menu-btn {
    display: none;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 5px;
    width: 40px;
    height: 40px;
    border: 1px solid rgba(27, 63, 110, 0.14);
    border-radius: 8px;
    background: transparent;
    cursor: pointer;
    padding: 0;
    transition:
      background 0.2s ease,
      border-color 0.2s ease;
  }

  .menu-btn:hover {
    background: rgba(27, 63, 110, 0.05);
    border-color: rgba(27, 63, 110, 0.22);
  }

  .bar {
    display: block;
    width: 18px;
    height: 1.5px;
    border-radius: 99px;
    background: #1b3f6e;
    transition:
      transform 0.25s ease,
      opacity 0.25s ease;
  }

  .menu-btn.is-open .bar:nth-child(1) {
    transform: translateY(6.5px) rotate(45deg);
  }
  .menu-btn.is-open .bar:nth-child(2) {
    opacity: 0;
  }
  .menu-btn.is-open .bar:nth-child(3) {
    transform: translateY(-6.5px) rotate(-45deg);
  }

  /* ════════════════════════════════════
     MOBILE DRAWER
  ════════════════════════════════════ */
  .mobile-menu {
    overflow: hidden;
    max-height: 0;
    background: #fff;
    border-top: 1px solid rgba(27, 63, 110, 0.07);
    transition: max-height 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .mobile-menu.is-open {
    max-height: 480px;
  }

  .mobile-menu nav {
    padding: 8px 16px 4px;
    display: flex;
    flex-direction: column;
  }

  .mobile-link {
    display: block;
    padding: 13px 10px;
    font-family: "Inter", sans-serif;
    font-size: 15px;
    font-weight: 500;
    color: #2c3e55;
    text-decoration: none;
    border-bottom: 1px solid rgba(27, 63, 110, 0.06);
    transition:
      color 0.2s ease,
      padding-left 0.2s ease;
  }

  .mobile-link:last-child {
    border-bottom: none;
  }

  .mobile-link:hover {
    color: #1b3f6e;
    padding-left: 16px;
  }

  .mobile-cta {
    display: block;
    margin: 12px 16px 16px;
    padding: 14px 20px;
    border-radius: 8px;
    background: #e8623a;
    font-family: "Plus Jakarta Sans", sans-serif;
    font-size: 14px;
    font-weight: 700;
    color: #fff;
    text-align: center;
    text-decoration: none;
    transition: background 0.2s ease;
  }

  .mobile-cta:hover {
    background: #d4542f;
  }

  /* ════════════════════════════════════
     RESPONSIVE
  ════════════════════════════════════ */
  @media (max-width: 860px) {
    .nav-links,
    .nav-cta {
      display: none;
    }

    .menu-btn {
      display: flex;
    }
  }

  @media (max-width: 480px) {
    .nav-inner {
      height: 64px;
      padding: 0 16px;
    }

    .brand-logo {
      width: 34px;
      height: 34px;
    }

    .brand-text {
      font-size: 14px;
    }
  }

  :global(body.menu-open) {
    overflow: hidden;
  }
</style>
