---
const navItems = [
  { label: "Inicio", href: "#inicio" },
  { label: "Problema", href: "#problema" },
  { label: "Solucion", href: "#solucion" },
  { label: "Planes", href: "#planes" },
  { label: "Contacto", href: "#contacto" },
];
---

<header class="navbar" id="navbar">
  <nav class="nav-container" aria-label="Navegación principal">
    <a href="#inicio" class="brand" aria-label="Nexflow Connect">
      <img
        src="/logo solid color 160 sin fondo.svg"
        alt="Nexflow Connect"
        class="brand-logo"
      />
      <span class="brand-text">Nexflow Connect</span>
    </a>

    <ul class="nav-links">
      {
        navItems.map((item) => (
          <li>
            <a href={item.href}>{item.label}</a>
          </li>
        ))
      }
    </ul>

    <a href="#contacto" class="nav-cta"> Quiero más reservas </a>

    <button
      class="menu-btn"
      id="menuBtn"
      aria-label="Abrir menú"
      aria-expanded="false"
    >
      <span></span>
      <span></span>
      <span></span>
    </button>
  </nav>

  <div class="mobile-menu" id="mobileMenu">
    {navItems.map((item) => <a href={item.href}>{item.label}</a>)}

    <a href="#contacto" class="mobile-cta"> Agenda un diagnóstico </a>
  </div>
</header>

<script>
  const navbar = document.getElementById("navbar");
  const menuBtn = document.getElementById("menuBtn");
  const mobileMenu = document.getElementById("mobileMenu");
  const mobileLinks = mobileMenu?.querySelectorAll("a");

  menuBtn?.addEventListener("click", () => {
    const isOpen = menuBtn.classList.toggle("is-open");
    mobileMenu?.classList.toggle("is-open");
    menuBtn.setAttribute("aria-expanded", String(isOpen));
  });

  mobileLinks?.forEach((link) => {
    link.addEventListener("click", () => {
      menuBtn?.classList.remove("is-open");
      mobileMenu?.classList.remove("is-open");
      menuBtn?.setAttribute("aria-expanded", "false");
    });
  });

  window.addEventListener("scroll", () => {
    if (window.scrollY > 16) {
      navbar?.classList.add("is-scrolled");
    } else {
      navbar?.classList.remove("is-scrolled");
    }
  });
</script>

<style>
  .navbar {
    position: fixed;
    top: 0;
    left: 0;
    z-index: 1000;
    width: 100%;
    padding: 18px 20px;
    transition:
      padding 0.3s ease,
      background 0.3s ease,
      box-shadow 0.3s ease;
  }

  .navbar.is-scrolled {
    padding: 10px 20px;
    background: rgba(244, 246, 251, 0.86);
    backdrop-filter: blur(18px);
    box-shadow: 0 12px 34px rgba(27, 63, 110, 0.12);
  }

  .nav-container {
    max-width: 1180px;
    margin: 0 auto;
    height: 68px;
    padding: 0 16px;
    border: 1px solid rgba(232, 237, 245, 0.85);
    border-radius: 999px;
    background: rgba(244, 246, 251, 0.78);
    backdrop-filter: blur(18px);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
  }

  .brand-logo {
    width: 42px;
    height: 42px;
    object-fit: contain;
  }

  .brand-text {
    font-family: "Plus Jakarta Sans", sans-serif;
    font-weight: 800;
    font-size: 16px;
    color: #1b3f6e;
    letter-spacing: -0.03em;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 26px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav-links a {
    position: relative;
    font-family: "Inter", sans-serif;
    font-size: 14px;
    font-weight: 500;
    color: #2c3e55;
    text-decoration: none;
    transition: color 0.25s ease;
  }

  .nav-links a::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: -7px;
    width: 0;
    height: 2px;
    border-radius: 99px;
    background: #e8623a;
    transition: width 0.25s ease;
  }

  .nav-links a:hover {
    color: #1b3f6e;
  }

  .nav-links a:hover::after {
    width: 100%;
  }

  .nav-cta,
  .mobile-cta {
    font-family: "Plus Jakarta Sans", sans-serif;
    font-size: 14px;
    font-weight: 700;
    color: #ffffff;
    background: #e8623a;
    text-decoration: none;
    padding: 13px 20px;
    border-radius: 999px;
    box-shadow: 0 12px 28px rgba(232, 98, 58, 0.28);
    transition:
      transform 0.25s ease,
      box-shadow 0.25s ease;
  }

  .nav-cta:hover,
  .mobile-cta:hover {
    transform: translateY(-2px);
    box-shadow: 0 16px 34px rgba(232, 98, 58, 0.36);
  }

  .menu-btn {
    display: none;
    width: 44px;
    height: 44px;
    border: 0;
    border-radius: 50%;
    background: #1b3f6e;
    cursor: pointer;
    position: relative;
  }

  .menu-btn span {
    display: block;
    width: 18px;
    height: 2px;
    margin: 4px auto;
    border-radius: 99px;
    background: #ffffff;
    transition:
      transform 0.25s ease,
      opacity 0.25s ease;
  }

  .menu-btn.is-open span:nth-child(1) {
    transform: translateY(6px) rotate(45deg);
  }

  .menu-btn.is-open span:nth-child(2) {
    opacity: 0;
  }

  .menu-btn.is-open span:nth-child(3) {
    transform: translateY(-6px) rotate(-45deg);
  }

  .mobile-menu {
    display: none;
  }

  @media (max-width: 900px) {
    .nav-links,
    .nav-cta {
      display: none;
    }

    .menu-btn {
      display: block;
    }

    .brand-text {
      font-size: 15px;
    }

    .mobile-menu {
      display: flex;
      flex-direction: column;
      gap: 6px;
      max-width: 1180px;
      margin: 10px auto 0;
      padding: 14px;
      border-radius: 28px;
      background: rgba(244, 246, 251, 0.96);
      backdrop-filter: blur(18px);
      box-shadow: 0 20px 50px rgba(27, 63, 110, 0.16);
      transform: translateY(-12px);
      opacity: 0;
      pointer-events: none;
      transition:
        opacity 0.25s ease,
        transform 0.25s ease;
    }

    .mobile-menu.is-open {
      opacity: 1;
      transform: translateY(0);
      pointer-events: auto;
    }

    .mobile-menu a {
      font-family: "Inter", sans-serif;
      font-size: 15px;
      font-weight: 600;
      color: #2c3e55;
      text-decoration: none;
      padding: 14px 16px;
      border-radius: 18px;
      transition:
        background 0.2s ease,
        color 0.2s ease;
    }

    .mobile-menu a:hover {
      background: #e8edf5;
      color: #1b3f6e;
    }

    .mobile-cta {
      text-align: center;
      margin-top: 8px;
      color: #ffffff !important;
    }
  }

  @media (max-width: 480px) {
    .navbar {
      padding: 12px;
    }

    .nav-container {
      height: 62px;
      padding: 0 12px;
    }

    .brand-logo {
      width: 38px;
      height: 38px;
    }

    .brand-text {
      max-width: 120px;
      line-height: 1.05;
    }
  }
</style>
