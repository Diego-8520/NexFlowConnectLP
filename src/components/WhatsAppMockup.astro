    }
  }
  @keyframes pulse {
    0%,
    100% {
      box-shadow: 0 0 0 3px rgba(37, 211, 102, 0.28);
    }
    50% {
      box-shadow: 0 0 0 6px rgba(37, 211, 102, 0.08);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .scene *,
    .phone-wrap {
      animation: none !important;
      opacity: 1 !important;
      transform: none !important;
    }
  }
</style>

