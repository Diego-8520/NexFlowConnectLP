    z-index: 5;
  }

  .msg-1 {
    animation: bubbleIn 0.35s ease 0.7s forwards;
  }
  .msg-2 {
    animation: bubbleIn 0.35s ease 1.4s forwards;
  }
  .msg-3 {
    animation:
      bubbleIn 0.3s ease 2.1s forwards,
      typingHide 0.2s ease 3s forwards;
  }
  .msg-4 {
    animation: bubbleIn 0.35s ease 3.2s forwards;
  }
  .msg-5 {
    animation: bubbleIn 0.35s ease 3.9s forwards;
  }
  .msg-6 {
    animation: bubbleIn 0.35s ease 4.5s forwards;
  }
  .msg-7 {
    animation: confirmIn 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) 5.3s forwards;
  }

  @keyframes bubbleIn {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  @keyframes typingHide {
    to {
      opacity: 0;
      max-height: 0;
      padding: 0;
      margin: 0;
      overflow: hidden;
    }
  }
  @keyframes confirmIn {
    to {
      opacity: 1;
      transform: scale(1);
    }
  }
  @keyframes badgeIn {
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }
  @keyframes fadeDown {
    from {
      opacity: 0;
      transform: translateY(-8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  @keyframes typingDot {
    0%,
    60%,
    100% {
      transform: translateY(0);
      opacity: 0.4;
    }
    30% {
      transform: translateY(-4px);
      opacity: 1;
    }
  }
  @keyframes floatPhone {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
