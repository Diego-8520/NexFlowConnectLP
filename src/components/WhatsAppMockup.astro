    padding: 5px 8px;
    margin: 2px auto 5px;
    text-align: center;
    line-height: 1.4;
    max-width: 88%;
  }

  .bubble {
    max-width: 82%;
    padding: 6px 8px 16px;
    border-radius: 7.5px;
    position: relative;
