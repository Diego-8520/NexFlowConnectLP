    flex-direction: column;
    gap: 2px;
    min-height: 280px;
  }

  .wa-encrypted {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 4px;
    font-size: 9.5px;
    color: #8696a0;
    font-family: "Inter", sans-serif;
