---
import WhatsAppMockup from "./WhatsAppMockup.astro";
---

<section
  id="inicio"
  class="relative isolate overflow-hidden bg-[#1B3F6E] px-6 pb-20 pt-36 text-white sm:pt-40 md:pb-28 md:pt-44"
>
  <div
    class="absolute inset-0 -z-10 bg-[linear-gradient(135deg,#1B3F6E,#2A6BB5,#E8623A)]"
  >
  </div>

  <div
    class="absolute -right-32 -top-32 -z-10 h-96 w-96 rounded-full bg-white/15 blur-3xl animate-pulse"
  >
  </div>
  <div
    class="absolute bottom-0 left-0 -z-10 h-72 w-72 rounded-full bg-[#E8623A]/30 blur-3xl"
  >
  </div>

  <div
    class="absolute inset-0 -z-10 opacity-[0.08] bg-[linear-gradient(to_right,#ffffff_1px,transparent_1px),linear-gradient(to_bottom,#ffffff_1px,transparent_1px)] bg-[size:48px_48px]"
  >
  </div>

  <div
    class="mx-auto grid max-w-6xl items-center gap-14 md:grid-cols-[1.08fr_0.92fr]"
  >
    <div>
      <div
        class="reveal inline-flex items-center gap-2 rounded-full border border-white/20 bg-white/10 px-4 py-2 text-[11px] font-bold uppercase tracking-[0.18em] text-[#FBE8E2] backdrop-blur"
      >
        Para hostales, ecohabs y alojamientos
      </div>

      <h1
        class="reveal delay-100 mt-6 max-w-4xl font-['Plus_Jakarta_Sans'] text-4xl font-extrabold leading-[1.05] tracking-[-0.03em] sm:text-5xl md:text-6xl"
      >
        Convierte más visitas en
        <span class="text-[#FBE8E2]">reservas directas</span>
      </h1>

      <p
        class="reveal delay-200 mt-6 max-w-2xl font-['Inter'] text-base leading-8 text-white/85 sm:text-lg"
      >
        Organizamos tu presencia digital para que tus clientes te encuentren
        fácil, te contacten rápido y reserven sin fricción.
      </p>

      <div class="reveal delay-300 mt-8 flex flex-col gap-4 sm:flex-row">
        <a
          href="#planes"
          class="inline-flex justify-center rounded-2xl bg-[#E8623A] px-6 py-4 font-['Plus_Jakarta_Sans'] text-sm font-bold text-white shadow-xl shadow-[#E8623A]/25 transition duration-300 hover:-translate-y-1 hover:shadow-2xl hover:shadow-[#E8623A]/35"
        >
          Ver planes
        </a>

        <a
          href="#contacto"
          class="inline-flex justify-center rounded-2xl border border-white/30 bg-white/10 px-6 py-4 font-['Plus_Jakarta_Sans'] text-sm font-bold text-white backdrop-blur transition duration-300 hover:-translate-y-1 hover:bg-white/15"
        >
          Agenda un diagnóstico
        </a>
      </div>

      <div
        class="reveal delay-300 mt-8 grid max-w-xl gap-3 font-['Inter'] text-sm text-white/80 sm:grid-cols-3"
      >
        <div
          class="rounded-2xl border border-white/15 bg-white/10 p-4 backdrop-blur transition duration-300 hover:-translate-y-1 hover:bg-white/15"
        >
          <strong class="block text-white">Contacto claro</strong>
          WhatsApp visible
        </div>

        <div
          class="rounded-2xl border border-white/15 bg-white/10 p-4 backdrop-blur transition duration-300 hover:-translate-y-1 hover:bg-white/15"
        >
          <strong class="block text-white">Más confianza</strong>
          Web profesional
        </div>

        <div
          class="rounded-2xl border border-white/15 bg-white/10 p-4 backdrop-blur transition duration-300 hover:-translate-y-1 hover:bg-white/15"
        >
          <strong class="block text-white">Menos fricción</strong>
          Reserva directa
        </div>
      </div>
    </div>

    <WhatsAppMockup />
  </div>
</section>

<style>
  .reveal {
    animation: revealUp 0.8s ease both;
  }

  .delay-100 {
    animation-delay: 0.1s;
  }

  .delay-200 {
    animation-delay: 0.2s;
  }

  .delay-300 {
    animation-delay: 0.3s;
  }

  .hero-card {
    animation: floatCard 5.5s ease-in-out infinite;
  }

  .floating-badge {
    animation: floatBadge 4.5s ease-in-out infinite;
  }

  @keyframes revealUp {
    from {
      opacity: 0;
      transform: translateY(18px);
    }

    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes floatCard {
    0%,
    100% {
      transform: translateY(0);
    }

    50% {
      transform: translateY(-10px);
    }
  }

  @keyframes floatBadge {
    0%,
    100% {
      transform: translateY(0) rotate(-1deg);
    }

    50% {
      transform: translateY(-8px) rotate(1deg);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .reveal,
    .hero-card,
    .floating-badge {
      animation: none;
    }
  }
</style>
