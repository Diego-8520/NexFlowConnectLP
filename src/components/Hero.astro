---
import WhatsAppMockup from "./WhatsAppMockup.astro";
---

<section
  id="inicio"
  class="relative isolate overflow-hidden bg-[#1B3F6E] px-6 pb-20 pt-36 text-white sm:pt-40 md:pb-28 md:pt-44"
>
  <!-- Gradient: used ONLY here as per brand rules -->
  <div
    class="absolute inset-0 -z-10 bg-[linear-gradient(135deg,#1B3F6E,#2A6BB5,#E8623A)]"
  >
  </div>

  <!-- Ambient blobs -->
  <div
    class="absolute -right-32 -top-32 -z-10 h-96 w-96 rounded-full bg-white/15 blur-3xl animate-pulse"
  >
  </div>
  <div
    class="absolute bottom-0 left-0 -z-10 h-72 w-72 rounded-full bg-[#E8623A]/30 blur-3xl"
  >
  </div>
  <div
    class="absolute left-1/2 top-1/4 -z-10 h-64 w-64 -translate-x-1/2 rounded-full bg-white/5 blur-3xl"
  >
  </div>

  <!-- Grid overlay -->
  <div
    class="absolute inset-0 -z-10 opacity-[0.06] bg-[linear-gradient(to_right,#ffffff_1px,transparent_1px),linear-gradient(to_bottom,#ffffff_1px,transparent_1px)] bg-size-[48px_48px]"
  >
  </div>

  <div
    class="mx-auto grid max-w-6xl items-center gap-14 md:grid-cols-[1.08fr_0.92fr]"
  >
    <!-- Left: copy -->
    <div>
      <div class="hero-badge">
        <span class="badge-dot"></span>
        Para hostales, ecohabs y alojamientos pequeños
      </div>

      <h1 class="hero-title">
        Convierte más visitas en
        <span class="hero-title-accent">reservas directas</span>
      </h1>

      <p class="hero-subtitle">
        Organizamos tu presencia digital para que los clientes te encuentren
        fácil, te contacten rápido y reserven sin depender tanto de plataformas
        externas.
      </p>

      <div class="hero-actions">
        <a href="#contacto" class="btn-primary">
          Quiero más reservas directas
        </a>
        <a href="#planes" class="btn-ghost"> Ver planes →</a>
      </div>

      <!-- Trust strips -->
      <div class="trust-grid">
        <div class="trust-item">
          <strong>Resultados en días</strong>
          <span>No en semanas</span>
        </div>
        <div class="trust-item">
          <strong>Sin tecnicismos</strong>
          <span>Hablas con personas</span>
        </div>
        <div class="trust-item">
          <strong>WhatsApp directo</strong>
          <span>Contacto inmediato</span>
        </div>
      </div>
    </div>

    <!-- Right: mockup -->
    <WhatsAppMockup />
  </div>
</section>

<style>
  /* ── Hero label badge ── */
  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    border: 1px solid rgba(255, 255, 255, 0.22);
    background: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(12px);
    border-radius: 999px;
    padding: 8px 18px;
    font-family: "Plus Jakarta Sans", sans-serif;
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: #fbe8e2;
    animation: revealDown 0.6s ease 0.05s both;
  }

  .badge-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #e8623a;
    flex-shrink: 0;
    box-shadow: 0 0 0 3px rgba(232, 98, 58, 0.3);
    animation: pulseDot 2.4s ease-in-out infinite;
  }

  /* ── Hero title ── */
  .hero-title {
    margin-top: 24px;
    font-family: "Plus Jakarta Sans", sans-serif;
    font-size: clamp(38px, 5.5vw, 62px);
    font-weight: 800;
    line-height: 1.04;
    letter-spacing: -0.03em;
    color: white;
    animation: revealUp 0.75s ease 0.12s both;
  }

  .hero-title-accent {
    display: block;
    color: #fbe8e2;
  }

  /* ── Hero subtitle ── */
  .hero-subtitle {
    margin-top: 22px;
    max-width: 520px;
    font-family: "Inter", sans-serif;
    font-size: 17px;
    line-height: 1.75;
    color: rgba(255, 255, 255, 0.84);
    animation: revealUp 0.75s ease 0.24s both;
  }

  /* ── CTA buttons ── */
  .hero-actions {
    margin-top: 32px;
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    animation: revealUp 0.75s ease 0.36s both;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 15px 28px;
    border-radius: 14px;
    background: #e8623a;
    font-family: "Plus Jakarta Sans", sans-serif;
    font-size: 14px;
    font-weight: 800;
    color: white;
    text-decoration: none;
    letter-spacing: 0.01em;
    box-shadow:
      0 14px 32px rgba(232, 98, 58, 0.32),
      0 4px 8px rgba(232, 98, 58, 0.2);
    transition:
      transform 0.25s cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow 0.25s cubic-bezier(0.22, 1, 0.36, 1),
      background 0.2s ease;
  }

  .btn-primary:hover {
    background: #d4552f;
    transform: translateY(-2px);
    box-shadow:
      0 20px 44px rgba(232, 98, 58, 0.42),
      0 8px 16px rgba(232, 98, 58, 0.24);
  }

  .btn-ghost {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 15px 24px;
    border-radius: 14px;
    border: 1px solid rgba(255, 255, 255, 0.28);
    background: rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(10px);
    font-family: "Plus Jakarta Sans", sans-serif;
    font-size: 14px;
    font-weight: 700;
    color: white;
    text-decoration: none;
    transition:
      transform 0.25s ease,
      background 0.2s ease,
      border-color 0.2s ease;
  }

  .btn-ghost:hover {
    background: rgba(255, 255, 255, 0.14);
    border-color: rgba(255, 255, 255, 0.42);
    transform: translateY(-2px);
  }

  /* ── Trust grid ── */
  .trust-grid {
    margin-top: 28px;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 10px;
    animation: revealUp 0.75s ease 0.48s both;
  }

  .trust-item {
    border: 1px solid rgba(255, 255, 255, 0.14);
    background: rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(12px);
    border-radius: 14px;
    padding: 14px 16px;
    transition:
      background 0.2s ease,
      transform 0.22s ease;
  }

  .trust-item:hover {
    background: rgba(255, 255, 255, 0.14);
    transform: translateY(-2px);
  }

  .trust-item strong {
    display: block;
    font-family: "Plus Jakarta Sans", sans-serif;
    font-size: 13px;
    font-weight: 800;
    color: white;
    letter-spacing: -0.01em;
  }

  .trust-item span {
    display: block;
    margin-top: 3px;
    font-family: "Inter", sans-serif;
    font-size: 12px;
    color: rgba(255, 255, 255, 0.68);
  }

  /* ── Keyframes (hero fires immediately, no scroll needed) ── */
  @keyframes revealUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes revealDown {
    from {
      opacity: 0;
      transform: translateY(-12px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes pulseDot {
    0%,
    100% {
      box-shadow: 0 0 0 3px rgba(232, 98, 58, 0.3);
    }
    50% {
      box-shadow: 0 0 0 7px rgba(232, 98, 58, 0.08);
    }
  }

  /* ── Responsive ── */
  @media (max-width: 640px) {
    .trust-grid {
      grid-template-columns: 1fr;
    }

    .hero-actions {
      flex-direction: column;
    }

    .btn-primary,
    .btn-ghost {
      width: 100%;
      justify-content: center;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-badge,
    .hero-title,
    .hero-subtitle,
    .hero-actions,
    .trust-grid,
    .badge-dot {
      animation: none;
      opacity: 1;
    }
  }
</style>
