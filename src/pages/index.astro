---
import "../styles/global.css";

import Navbar from "../components/Navbar.astro";
import Hero from "../components/Hero.astro";
import Problem from "../components/Problem.astro";
import HowItWorks from "../components/HowItWorks.astro";
import Plans from "../components/Plans.astro";
import Contact from "../components/Contact.astro";
import Footer from "../components/Footer.astro";
import VercelMetrics from "../components/VercelMetrics.astro";
---

<head>
  <!-- Básico -->
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <!-- Título (enfocado en resultado) -->
  <title>NexFlow Connect | Más reservas directas para tu alojamiento</title>

  <!-- Descripción (clave para conversión y SEO) -->
  <meta
    name="description"
    content="Haz que tu alojamiento reciba más contactos y reservas directas. Organizamos tu presencia digital para que te encuentren fácil y te escriban sin fricción."
  />

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- Open Graph (para compartir en WhatsApp, Facebook, etc.) -->
  <meta property="og:title" content="NexFlow Connect" />
  <meta
    property="og:description"
    content="Convierte tu presencia digital en más contactos y reservas directas."
  />
  <meta property="og:type" content="website" />
  <meta property="og:image" content="/og-image.jpg" />

  <!-- Tema del navegador (coherente con tu marca) -->
  <meta name="theme-color" content="#1B3F6E" />
</head>

<main class="min-h-screen bg-[#F4F6FB] text-[#2C3E55]">
  <Navbar />
  <Hero />
  <Problem />
  <HowItWorks />
  <Plans />
  <Contact />
  <Footer />
  <VercelMetrics />
</main>
